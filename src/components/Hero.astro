---
import { Button } from "@/components/ui/button";

interface Props {
  name?: string;
  specialty?: string;
  location?: string;
  imageUrl?: string;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  name = "Dr. Pablo Carrara",
  specialty = "Gastroenterólogo - Endoscopia Digestiva",
  location = "Santa Fe, Argentina",
  imageUrl = "/images/PabloCarraraProfile.jpg",
  imageAlt = "Dr. Pablo Carrara",
  ctaText = "Sacar Turno",
  ctaHref = "#lugares",
} = Astro.props;
---

<section class="max-w-[1128px] mx-auto px-6 mb-16">
  <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.08)] p-8 md:p-12 flex flex-col items-center text-center transition-all duration-300 hover:shadow-[0px_8px_24px_rgba(0,0,0,0.12)]">
    <div class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-white shadow-md mb-6 overflow-hidden">
      <img
        src={imageUrl}
        alt={imageAlt}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <h1 class="text-3xl md:text-[40px] font-bold text-on-background mb-2 tracking-tight">
      {name}
    </h1>

    <p class="text-xl md:text-2xl font-semibold text-secondary mb-1">
      {specialty}
    </p>

    <div class="flex items-center gap-2 text-on-surface-variant text-base mb-6">
      <span class="material-symbols-outlined">location_on</span>
      <span>{location}</span>
    </div>

    <Button
      variant="default"
      size="pill"
      href={ctaHref}
      className="px-6 py-2"
    >
      {ctaText}
    </Button>
  </div>
</section>
